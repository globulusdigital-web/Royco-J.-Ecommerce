{
  "name": "royco-jewellers-store",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build && node local-server/app.mjs",
    "start": "node local-server/app.mjs",
    "dev:frontend": "vite --mode frontend",
    "build": "vite build",
    "preview": "node local-server/app.mjs",
    "test": "node --test --test-isolation=none tests/*.test.mjs local-server/*.test.mjs",
    "check": "pnpm test && pnpm build"
  },
  "dependencies": {
    "lucide-react": "latest",
    "pg": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "three": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.15.1"
}
