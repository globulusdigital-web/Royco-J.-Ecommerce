NODE_ENV=development
SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_USER=Admin@Royco
ADMIN_PASSWORD=replace-with-a-unique-admin-password
PUBLIC_SITE_URL=http://127.0.0.1:4173

# Production SMS OTP (Twilio Verify)
TWILIO_ACCOUNT_SID=replace-from-twilio
TWILIO_AUTH_TOKEN=replace-from-twilio
TWILIO_VERIFY_SERVICE_SID=replace-from-twilio

# Razorpay test keys first; switch to live keys only after verification
RAZORPAY_KEY_ID=rzp_test_replace
RAZORPAY_KEY_SECRET=replace-from-razorpay
